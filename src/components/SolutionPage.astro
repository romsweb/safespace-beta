---
import Base from '../layouts/Base.astro';
import Header from './Header.astro';
import Footer from './Footer.astro';
import { getSolution, solutions, type Solution } from '../data/solutions';
import { u } from '../lib/url';

interface Props {
  slug: string;
}
const home = u('/beta-recif');
const sol: Solution = getSolution(Astro.props.slug);
const path = `/solutions/${sol.slug}`;
const site = 'https://safespace.nc';
const related = sol.related.map((slug) => solutions.find((s) => s.slug === slug)!).filter(Boolean);

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: sol.navLabel,
  description: sol.metaDescription,
  url: site + path,
  provider: { '@id': site + '/#organization' },
  areaServed: ['Nouvelle-Calédonie', 'Pacifique Sud'],
  serviceType: sol.kicker,
};
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: sol.faq.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Accueil', item: site },
    { '@type': 'ListItem', position: 2, name: 'Solutions', item: site + '/#solutions' },
    { '@type': 'ListItem', position: 3, name: sol.navLabel, item: site + path },
  ],
};
---

<Base title={sol.metaTitle} description={sol.metaDescription} path={path}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <Header />

  <main>
    <!-- Hero -->
    <section class="hero">
      <div class="hero-inner">
        <nav class="crumbs" aria-label="Fil d’Ariane">
          <a href={home}>Accueil</a>
          <span aria-hidden="true">›</span>
          <a href={`${home}#solutions`}>Solutions</a>
          <span aria-hidden="true">›</span>
          <span aria-current="page">{sol.navLabel}</span>
        </nav>
        <p class="kicker">{sol.kicker}</p>
        <h1>{sol.h1}</h1>
        <p class="lead">{sol.heroLead}</p>
        <div class="hero-ctas">
          <a class="btn-primary" href={`${home}#contact`}>{sol.pricing.ctaLabel}</a>
          <a class="btn-ghost" href="tel:+687259667">Parler à un expert — +687 25 96 67</a>
        </div>
        <p class="hero-trial">✓ {sol.pricing.trial} · ✓ Sans engagement · ✓ Support calédonien</p>
      </div>
      <div class="hero-depth" aria-hidden="true"></div>
    </section>

    <!-- Problème -->
    <section class="problem">
      <div class="section-inner">
        <h2>{sol.problemTitle}</h2>
        <ul class="problem-list">
          {sol.problemPoints.map((p) => (
            <li>
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 9v4m0 4h.01M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0Z" stroke="var(--orange)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              <p>{p}</p>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- Features -->
    <section class="features">
      <div class="section-inner">
        <h2>Ce que SAFESPACE met en place</h2>
        <div class="feature-grid">
          {sol.features.map((f) => (
            <article class="feature-card">
              <h3>{f.title}</h3>
              <p>{f.desc}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- Pricing + local -->
    <section class="pricing">
      <div class="section-inner pricing-grid">
        <div class="price-card">
          <p class="price-label">À partir de</p>
          <p class="price">{sol.pricing.from}</p>
          <p class="price-unit">{sol.pricing.unit}</p>
          <p class="price-trial">{sol.pricing.trial}</p>
          <a class="btn-primary" href={`${home}#contact`}>{sol.pricing.ctaLabel}</a>
          <p class="price-note">Sans engagement — aucune carte bancaire demandée</p>
        </div>
        <div class="local-note">
          <h2>Opéré depuis Nouméa</h2>
          <p>{sol.localNote}</p>
          <ul class="local-points">
            <li>🇳🇨 Équipe locale, support en français</li>
            <li>🛰️ Hébergement au choix : NC · Australie · France</li>
            <li>🕑 600+ entreprises protégées depuis 2007</li>
          </ul>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="faq">
      <div class="section-inner">
        <h2>Questions fréquentes</h2>
        <div class="faq-list">
          {sol.faq.map((f) => (
            <details>
              <summary>{f.q}</summary>
              <p>{f.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- Related -->
    <section class="related">
      <div class="section-inner">
        <h2>Souvent combiné avec</h2>
        <div class="related-grid">
          {related.map((r) => (
            <a class="related-card" href={u(`/solutions/${r.slug}`)}>
              <strong>{r.navLabel}</strong>
              <span>{r.navHint}</span>
              <em>Découvrir →</em>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA final -->
    <section class="final-cta" id="essai">
      <div class="section-inner">
        <h2>Prêt à sécuriser votre entreprise ?</h2>
        <p>Essai gratuit 30 jours, configuration accompagnée, sans engagement.</p>
        <div class="hero-ctas center">
          <a class="btn-primary" href={`${home}#contact`}>{sol.pricing.ctaLabel}</a>
          <a class="btn-whatsapp" href="https://wa.me/687259667" rel="noopener" target="_blank">Poser une question sur WhatsApp</a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Base>

<style>
  main {
    background: var(--blanc);
  }
  .section-inner {
    max-width: 1140px;
    margin: 0 auto;
    padding: 0 clamp(20px, 5vw, 48px);
  }

  /* Hero — la part du monde « Sous le Récif » sur chaque landing */
  .hero {
    position: relative;
    overflow: hidden;
    color: var(--blanc);
    background:
      radial-gradient(120% 90% at 85% -10%, color-mix(in srgb, var(--cyan) 22%, transparent), transparent 60%),
      radial-gradient(100% 120% at 10% 110%, color-mix(in srgb, var(--bleu) 40%, transparent), transparent 55%),
      linear-gradient(175deg, var(--abysse) 0%, var(--marine) 55%, var(--brand) 100%);
    padding: 160px 0 110px;
  }
  .hero-inner {
    position: relative;
    z-index: 1;
    max-width: 1140px;
    margin: 0 auto;
    padding: 0 clamp(20px, 5vw, 48px);
  }
  .hero-depth {
    position: absolute;
    inset: auto 0 -1px 0;
    height: 120px;
    background: linear-gradient(to bottom, transparent, var(--blanc));
    pointer-events: none;
  }
  .crumbs {
    display: flex;
    gap: 8px;
    font-size: 13px;
    opacity: 0.66;
    margin-bottom: 30px;
  }
  .crumbs a {
    text-decoration: none;
  }
  .crumbs a:hover {
    text-decoration: underline;
  }
  .kicker {
    font-family: var(--font-mono);
    font-size: 12.5px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--lagon);
    margin-bottom: 18px;
  }
  h1 {
    font-size: clamp(34px, 5.2vw, 62px);
    max-width: 17ch;
  }
  .lead {
    margin-top: 24px;
    font-size: clamp(16px, 1.6vw, 19px);
    line-height: 1.65;
    max-width: 62ch;
    opacity: 0.88;
  }
  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    margin-top: 36px;
  }
  .hero-ctas.center {
    justify-content: center;
  }
  .btn-primary {
    display: inline-block;
    font-weight: 600;
    font-size: 15.5px;
    text-decoration: none;
    color: #fff;
    background: linear-gradient(135deg, var(--orange), var(--orange-deep));
    padding: 15px 28px;
    border-radius: 99px;
    box-shadow: 0 8px 28px color-mix(in srgb, var(--orange) 40%, transparent);
    transition: transform 0.2s var(--ease-out), box-shadow 0.2s;
  }
  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 34px color-mix(in srgb, var(--orange) 52%, transparent);
  }
  .btn-ghost {
    display: inline-block;
    font-weight: 500;
    font-size: 15px;
    text-decoration: none;
    color: var(--blanc);
    border: 1px solid rgba(255, 255, 255, 0.32);
    padding: 14px 26px;
    border-radius: 99px;
    transition: border-color 0.2s, background 0.2s;
  }
  .btn-ghost:hover {
    border-color: var(--lagon);
    background: rgba(255, 255, 255, 0.06);
  }
  .btn-whatsapp {
    display: inline-block;
    font-weight: 600;
    font-size: 15px;
    text-decoration: none;
    color: #0d3b2e;
    background: #c3f3d9;
    padding: 15px 26px;
    border-radius: 99px;
    transition: transform 0.2s var(--ease-out);
  }
  .btn-whatsapp:hover {
    transform: translateY(-2px);
  }
  .hero-trial {
    margin-top: 22px;
    font-size: 13.5px;
    opacity: 0.72;
  }

  /* Problème */
  .problem {
    padding: 84px 0 30px;
  }
  h2 {
    font-size: clamp(26px, 3.4vw, 40px);
    color: var(--encre);
    max-width: 24ch;
  }
  .problem-list {
    list-style: none;
    margin: 36px 0 0;
    padding: 0;
    display: grid;
    gap: 18px;
  }
  .problem-list li {
    display: flex;
    gap: 16px;
    align-items: flex-start;
    background: color-mix(in srgb, var(--orange) 6%, var(--blanc));
    border: 1px solid color-mix(in srgb, var(--orange) 18%, transparent);
    border-radius: 14px;
    padding: 18px 22px;
    max-width: 820px;
  }
  .problem-list svg {
    flex-shrink: 0;
    margin-top: 3px;
  }
  .problem-list p {
    color: var(--encre-2);
  }

  /* Features */
  .features {
    padding: 74px 0;
  }
  .feature-grid {
    margin-top: 40px;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }
  .feature-card {
    background: var(--ecume);
    border: 1px solid color-mix(in srgb, var(--cyan) 16%, transparent);
    border-radius: 16px;
    padding: 26px 24px;
    transition: transform 0.25s var(--ease-out), box-shadow 0.25s;
  }
  .feature-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 16px 40px rgba(10, 37, 64, 0.1);
  }
  .feature-card h3 {
    font-size: 18.5px;
    color: var(--brand);
    margin-bottom: 10px;
  }
  .feature-card p {
    font-size: 14.5px;
    color: var(--encre-2);
  }

  /* Pricing */
  .pricing {
    padding: 30px 0 80px;
  }
  .pricing-grid {
    display: grid;
    grid-template-columns: 380px 1fr;
    gap: 44px;
    align-items: start;
  }
  .price-card {
    background: linear-gradient(165deg, var(--marine), var(--brand));
    color: var(--blanc);
    border-radius: 20px;
    padding: 36px 32px;
    box-shadow: 0 24px 60px rgba(10, 37, 64, 0.28);
  }
  .price-label {
    font-size: 13px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    opacity: 0.66;
  }
  .price {
    font-family: var(--font-display);
    font-size: 44px;
    font-weight: 600;
    margin-top: 6px;
  }
  .price-unit {
    opacity: 0.75;
    margin-bottom: 14px;
  }
  .price-trial {
    color: var(--lagon);
    font-weight: 600;
    margin-bottom: 24px;
  }
  .price-note {
    margin-top: 14px;
    font-size: 12.5px;
    opacity: 0.62;
  }
  .local-note h2 {
    margin-bottom: 18px;
  }
  .local-note > p {
    color: var(--encre-2);
    max-width: 58ch;
  }
  .local-points {
    list-style: none;
    padding: 0;
    margin: 24px 0 0;
    display: grid;
    gap: 10px;
    color: var(--encre-2);
  }

  /* FAQ */
  .faq {
    padding: 0 0 80px;
  }
  .faq-list {
    margin-top: 34px;
    max-width: 820px;
    display: grid;
    gap: 12px;
  }
  details {
    border: 1px solid color-mix(in srgb, var(--brand) 16%, transparent);
    border-radius: 14px;
    padding: 0 22px;
    background: var(--blanc);
    transition: border-color 0.2s;
  }
  details[open] {
    border-color: var(--cyan);
    background: color-mix(in srgb, var(--ecume) 60%, var(--blanc));
  }
  summary {
    cursor: pointer;
    font-weight: 600;
    font-size: 16px;
    padding: 18px 0;
    color: var(--brand);
    list-style: none;
    position: relative;
    padding-right: 34px;
  }
  summary::-webkit-details-marker {
    display: none;
  }
  summary::after {
    content: '+';
    position: absolute;
    right: 2px;
    top: 50%;
    transform: translateY(-50%);
    font-family: var(--font-display);
    font-size: 22px;
    color: var(--cyan);
    transition: transform 0.2s;
  }
  details[open] summary::after {
    content: '−';
  }
  details p {
    padding: 0 0 20px;
    color: var(--encre-2);
  }

  /* Related */
  .related {
    padding: 0 0 90px;
  }
  .related-grid {
    margin-top: 30px;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 18px;
  }
  .related-card {
    display: flex;
    flex-direction: column;
    gap: 8px;
    text-decoration: none;
    background: var(--ecume);
    border: 1px solid color-mix(in srgb, var(--cyan) 16%, transparent);
    border-radius: 16px;
    padding: 24px;
    transition: transform 0.25s var(--ease-out), box-shadow 0.25s;
  }
  .related-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 16px 40px rgba(10, 37, 64, 0.12);
  }
  .related-card strong {
    color: var(--brand);
    font-size: 16.5px;
  }
  .related-card span {
    font-size: 13.5px;
    color: var(--encre-2);
  }
  .related-card em {
    font-style: normal;
    font-size: 13.5px;
    font-weight: 600;
    color: var(--orange-deep);
    margin-top: 6px;
  }

  /* CTA final */
  .final-cta {
    background:
      radial-gradient(90% 120% at 50% 130%, color-mix(in srgb, var(--cyan) 26%, transparent), transparent 60%),
      linear-gradient(180deg, var(--marine), var(--abysse));
    color: var(--blanc);
    text-align: center;
    padding: 90px 0;
  }
  .final-cta h2 {
    color: var(--blanc);
    margin: 0 auto;
  }
  .final-cta p {
    margin: 16px auto 0;
    opacity: 0.82;
  }
  .final-cta .hero-ctas {
    margin-top: 34px;
  }

  @media (max-width: 920px) {
    .feature-grid,
    .related-grid {
      grid-template-columns: 1fr 1fr;
    }
    .pricing-grid {
      grid-template-columns: 1fr;
    }
    .price-card {
      max-width: 420px;
    }
  }
  @media (max-width: 600px) {
    .hero {
      padding: 130px 0 80px;
    }
    .feature-grid,
    .related-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
