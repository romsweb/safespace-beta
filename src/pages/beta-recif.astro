---
// VERSION BETA « SOUS LE RÉCIF » — film lagon/récif en 5 chapitres.
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import AfterFilm from '../components/AfterFilm.astro';
import { u } from '../lib/url';

const title = 'SAFESPACE by NOVATECH — Sauvegarde, PRA & Cybersécurité en Nouvelle-Calédonie';
const description =
  'Ransomware, incendie, cyclone : vos serveurs redémarrent en 2-4h sur nos infrastructures. Sauvegarde externalisée, PRA et cybersécurité pour 600+ entreprises calédoniennes depuis 2007. Essai gratuit 30 jours.';

const pillars = [
  {
    id: 'sauvegarder',
    depth: '-12 m',
    title: 'Sauvegarder',
    tag: 'Vos données, hors de vos murs',
    desc: 'Microsoft 365, serveurs, NAS : chaque nuit, tout part chiffré vers un stockage immuable — qu’un ransomware ne peut ni lire ni détruire.',
    links: [
      { href: u('/solutions/sauvegarde-microsoft-365'), label: 'Sauvegarde Microsoft 365' },
      { href: u('/solutions/sauvegarde-serveurs-nas'), label: 'Sauvegarde Serveurs & NAS' },
      { href: u('/solutions/services-veeam'), label: 'Services Veeam VCSP' },
    ],
  },
  {
    id: 'redemarrer',
    depth: '-24 m',
    title: 'Redémarrer',
    tag: 'Votre activité, en 2-4 h',
    desc: 'Incendie, panne, chiffrement : vos serveurs redémarrent sur notre infrastructure de secours pendant que les autres attendent du matériel.',
    links: [
      { href: u('/solutions/plan-reprise-activite'), label: 'Plan de Reprise d’Activité' },
      { href: u('/solutions/audit-securite'), label: 'Audit de Sécurité & Conformité' },
    ],
  },
  {
    id: 'defendre',
    depth: '-38 m',
    title: 'Défendre',
    tag: 'Les menaces, stoppées avant',
    desc: 'EDR sur chaque poste, blindage de la messagerie, équipes entraînées : l’attaque est détectée pendant qu’elle se prépare, pas après.',
    links: [
      { href: u('/solutions/protection-edr-xdr-mdr'), label: 'Protection EDR • XDR • MDR' },
      { href: u('/solutions/securite-email'), label: 'SafeSpace Email Security' },
      { href: u('/solutions/formation-anti-phishing'), label: 'Formation & Anti-Phishing' },
    ],
  },
];
---

<Base title={title} description={description} path="/beta-recif">
  <Fragment slot="head">
    <link rel="preload" href={u('/assets/hero-background-nc.jpg')} as="image" fetchpriority="high" />
  </Fragment>

  <Header anchorBase="" />

  <!-- ══════════════ LE FILM — « Sous le Récif » ══════════════ -->
  <main id="film">
    <!-- CH.1 — LA SURFACE -->
    <section class="scene" id="surface" aria-label="Chapitre 1 — La surface">
      <div class="surface-bg" style={`background-image:url('${u('/assets/hero-background-nc.jpg')}')`} aria-hidden="true"></div>
      <div class="surface-tint" aria-hidden="true"></div>
      <div class="hero-content">
        <p class="badge">🏝️ Made in Nouvelle-Calédonie — depuis 2007</p>
        <h1 class="hero-title">
          <span class="line">Sauvegarde, PRA</span>
          <span class="line">&amp; cybersécurité</span>
          <span class="line accent">en Nouvelle-Calédonie</span>
        </h1>
        <p class="hero-sub">
          Ransomware, incendie, cyclone : vos serveurs redémarrent en <strong>2-4&nbsp;h</strong> sur nos
          infrastructures. Plus de 600 entreprises et administrations calédoniennes protégées.
        </p>
        <div class="hero-ctas">
          <a class="btn-primary" href="#essai">Essai gratuit 30 jours</a>
          <a class="btn-ghost" href="tel:+687259667">Urgence&nbsp;? +687 25 96 67</a>
        </div>
      </div>
      <p class="scroll-hint" aria-hidden="true">Plongez<span class="hint-arrow">↓</span></p>
      <div class="water-veil" aria-hidden="true">
        <svg class="water-edge" viewBox="0 0 1440 110" preserveAspectRatio="none" aria-hidden="true">
          <path d="M0,60 C180,110 320,10 520,55 C720,100 880,15 1080,50 C1240,78 1360,30 1440,55 L1440,110 L0,110 Z" fill="var(--plongee-0)" />
        </svg>
        <div class="water-body"></div>
      </div>
    </section>

    <!-- CH.2 — LA PLONGÉE -->
    <section class="scene" id="plongee" aria-label="Chapitre 2 — La plongée">
      <div class="rays" aria-hidden="true">
        <i></i><i></i><i></i><i></i>
      </div>
      <div class="beat beat-plongee">
        <p class="chapter-tag">CH.02 — La plongée</p>
        <h2>Sous la surface,<br />vos données sont <em>ailleurs</em>.</h2>
        <p class="beat-sub">
          Hors de vos murs, hors de votre réseau, hors de portée. Chaque nuit, vos serveurs, NAS et
          Microsoft&nbsp;365 descendent chiffrés vers un stockage immuable — en Nouvelle-Calédonie,
          en Australie ou en France, c’est vous qui choisissez.
        </p>
      </div>
    </section>

    <!-- CH.3 — LE RÉCIF (traversée horizontale) -->
    <section class="scene" id="recif" aria-label="Chapitre 3 — Le récif">
      <div class="reef-glow" aria-hidden="true"></div>
      <div class="reef-track">
        <div class="reef-intro">
          <p class="chapter-tag">CH.03 — Le récif</p>
          <h2>Le plus grand lagon du monde est protégé par une barrière de corail.</h2>
          <p class="beat-sub">Vos données aussi. Longez le récif&nbsp;→</p>
        </div>
        {pillars.map((p, i) => (
          <article class="reef-panel" data-i={i}>
            <svg class="rack" viewBox="0 0 120 150" aria-hidden="true">
              <path class="coral c1" d="M20,150 C18,120 10,112 12,92 C14,76 26,72 24,56 C40,66 34,84 32,100 C30,120 34,134 36,150 Z" />
              <path class="coral c2" d="M96,150 C100,126 108,118 104,100 C101,86 90,80 94,64 C80,72 86,90 88,104 C90,124 86,136 84,150 Z" />
              <g class="unit">
                <rect x="34" y="34" width="52" height="112" rx="6" class="rack-body" />
                {[0, 1, 2, 3, 4].map((r) => (
                  <g>
                    <rect x="41" y={44 + r * 20} width="38" height="12" rx="3" class="rack-slot" />
                    <circle cx="73" cy={50 + r * 20} r="2.4" class="led" style={`animation-delay:${(i * 5 + r) * 0.35}s`} />
                  </g>
                ))}
              </g>
            </svg>
            <p class="panel-depth">{p.depth}</p>
            <h3>{p.title}</h3>
            <p class="panel-tag">{p.tag}</p>
            <p class="panel-desc">{p.desc}</p>
            <ul class="panel-links">
              {p.links.map((l) => (
                <li><a href={l.href}>{l.label} →</a></li>
              ))}
            </ul>
          </article>
        ))}
      </div>
    </section>

    <!-- CH.4 — LA TEMPÊTE -->
    <section class="scene" id="tempete" aria-label="Chapitre 4 — La tempête">
      <div class="storm-sky" aria-hidden="true"></div>
      <div class="flash" aria-hidden="true"></div>
      <div class="threats" aria-hidden="true">
        <div class="threat-row">
          <span>RANSOMWARE</span><span>CYCLONE</span><span>INCENDIE</span><span>PANNE</span><span>PHISHING</span><span>ÉMEUTES</span>
          <span>RANSOMWARE</span><span>CYCLONE</span><span>INCENDIE</span><span>PANNE</span><span>PHISHING</span><span>ÉMEUTES</span>
        </div>
      </div>
      <div class="beat beat-tempete">
        <p class="chapter-tag storm-tag">CH.04 — La tempête</p>
        <h2>En 2024, <em>740 entreprises</em> calédoniennes détruites ou sinistrées.</h2>
        <p class="beat-sub">
          Ransomwares sur des dizaines de PME — dont un fournisseur d’accès local. Incendies, cyclones,
          émeutes. La tempête passe toujours par ici.
        </p>
        <div class="calm-card">
          <p class="calm-label">Pendant ce temps, à −38&nbsp;m</p>
          <p class="calm-line">Vos données dorment au calme. Reprise&nbsp;: <strong class="chrono">2-4&nbsp;h</strong></p>
        </div>
      </div>
    </section>

    <!-- CH.5 — LE RETOUR -->
    <section class="scene" id="retour" aria-label="Chapitre 5 — Le retour">
      <div class="dawn" aria-hidden="true">
        <div class="sun"></div>
        <svg class="island" viewBox="0 0 1440 180" preserveAspectRatio="none" aria-hidden="true">
          <path d="M0,180 L0,150 C120,150 200,120 320,118 C420,116 470,90 560,86 C640,82 700,60 760,58 C830,56 900,84 990,92 C1100,102 1180,128 1300,134 C1360,137 1400,140 1440,142 L1440,180 Z" fill="#0b1d2e" />
        </svg>
      </div>
      <div class="beat beat-retour">
        <p class="chapter-tag">CH.05 — Le retour</p>
        <h2>Et lundi matin,<br />tout le monde <em>travaille</em>.</h2>
        <p class="beat-sub">
          Serveurs redémarrés, emails restaurés, équipes opérationnelles. Comme si rien ne s’était passé —
          parce que vous aviez décidé, avant, que rien ne se passerait.
        </p>
        <a class="btn-primary" href="#essai">Protéger mon entreprise</a>
      </div>
      <div class="seam" aria-hidden="true"></div>
    </section>
  </main>

  <!-- Altimètre / lecteur de chapitre -->
  <div class="altimeter" id="altimeter" aria-hidden="true">
    <span class="alt-chapter" id="alt-chapter">CH.01 — La surface</span>
    <span class="alt-depth" id="alt-depth">+120 m</span>
    <span class="alt-bar"><i id="alt-fill"></i></span>
  </div>

  <AfterFilm />
  <Footer anchorBase="" />

  <!-- Motion -->
  <script is:inline src={u('/vendor/gsap.min.js')} defer></script>
  <script is:inline src={u('/vendor/ScrollTrigger.min.js')} defer></script>
  <script is:inline src={u('/vendor/lenis.min.js')} defer></script>
  <script is:inline src={u('/js/film.js')} defer></script>
</Base>

<style>
  /* ═══ Le monde ═══ */
  :root {
    --plongee-0: #0e4d66;
    --plongee-1: #083248;
    --recif: #062338;
    --tempete: #041825;
    --dawn-orange: #ff9a62;
  }
  #film {
    position: relative;
    color: var(--blanc);
  }
  .scene {
    position: relative;
    min-height: 100vh;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .chapter-tag {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.26em;
    text-transform: uppercase;
    color: var(--lagon);
    margin-bottom: 20px;
  }
  .beat {
    position: relative;
    z-index: 3;
    max-width: 780px;
    padding: 0 clamp(20px, 5vw, 48px);
    text-align: center;
  }
  .beat h2 {
    font-size: clamp(30px, 4.6vw, 54px);
    color: var(--blanc);
  }
  .beat h2 em {
    font-style: normal;
    color: var(--lagon);
  }
  .beat-sub {
    margin: 22px auto 0;
    max-width: 58ch;
    font-size: clamp(15px, 1.5vw, 17.5px);
    line-height: 1.7;
    opacity: 0.82;
  }

  /* ═══ CH.1 — LA SURFACE ═══ */
  #surface {
    background: var(--abysse);
  }
  .surface-bg {
    position: absolute;
    inset: -6%;
    background-position: center 30%;
    background-size: cover;
    background-repeat: no-repeat;
    will-change: transform;
  }
  .surface-tint {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, color-mix(in srgb, var(--abysse) 78%, transparent) 0%, color-mix(in srgb, var(--marine) 30%, transparent) 45%, color-mix(in srgb, var(--plongee-0) 55%, transparent) 100%),
      radial-gradient(90% 60% at 70% 20%, color-mix(in srgb, var(--cyan) 14%, transparent), transparent 70%);
  }
  .hero-content {
    position: relative;
    z-index: 2;
    text-align: center;
    padding: 120px clamp(20px, 5vw, 48px) 60px;
    max-width: 1000px;
  }
  .badge {
    display: inline-block;
    font-size: 13.5px;
    font-weight: 500;
    padding: 9px 18px;
    border-radius: 99px;
    background: rgba(4, 18, 31, 0.55);
    border: 1px solid rgba(255, 255, 255, 0.18);
    -webkit-backdrop-filter: blur(8px);
    backdrop-filter: blur(8px);
    margin-bottom: 30px;
  }
  .hero-title {
    font-size: clamp(40px, 7vw, 88px);
    letter-spacing: -0.015em;
    line-height: 1.02;
  }
  .hero-title .line {
    display: block;
    overflow: hidden;
  }
  .hero-title .line > :global(span) {
    display: inline-block;
    will-change: transform;
  }
  .hero-title .accent {
    color: var(--lagon);
  }
  .hero-sub {
    margin: 26px auto 0;
    max-width: 58ch;
    font-size: clamp(15.5px, 1.6vw, 18.5px);
    line-height: 1.65;
    opacity: 0.9;
  }
  .hero-sub strong {
    color: var(--lagon);
  }
  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    justify-content: center;
    margin-top: 38px;
  }
  .btn-primary {
    display: inline-block;
    font-weight: 600;
    font-size: 15.5px;
    text-decoration: none;
    color: #fff;
    background: linear-gradient(135deg, var(--orange), var(--orange-deep));
    padding: 16px 30px;
    border-radius: 99px;
    box-shadow: 0 10px 32px color-mix(in srgb, var(--orange) 42%, transparent);
    transition: transform 0.2s var(--ease-out), box-shadow 0.2s;
  }
  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 14px 38px color-mix(in srgb, var(--orange) 55%, transparent);
  }
  .btn-ghost {
    display: inline-block;
    font-weight: 500;
    font-size: 15px;
    text-decoration: none;
    color: var(--blanc);
    border: 1px solid rgba(255, 255, 255, 0.36);
    padding: 15px 28px;
    border-radius: 99px;
    -webkit-backdrop-filter: blur(6px);
    backdrop-filter: blur(6px);
    transition: border-color 0.2s, background 0.2s;
  }
  .btn-ghost:hover {
    border-color: var(--lagon);
    background: rgba(255, 255, 255, 0.07);
  }
  .scroll-hint {
    position: absolute;
    bottom: 26px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 3;
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    opacity: 0.75;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .hint-arrow {
    display: inline-block;
    animation: bob 1.8s ease-in-out infinite;
  }
  @keyframes bob {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(6px); }
  }
  .water-veil {
    position: absolute;
    inset: 0;
    z-index: 4;
    transform: translateY(101%);
    will-change: transform;
    pointer-events: none;
  }
  .water-edge {
    position: absolute;
    top: -108px;
    left: 0;
    width: 100%;
    height: 110px;
  }
  .water-body {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, var(--plongee-0), var(--plongee-1));
  }

  /* ═══ CH.2 — LA PLONGÉE ═══ */
  #plongee {
    background: linear-gradient(180deg, var(--plongee-0) 0%, var(--plongee-1) 55%, var(--recif) 100%);
  }
  .rays {
    position: absolute;
    inset: -10% 0 0;
    overflow: hidden;
    pointer-events: none;
  }
  .rays i {
    position: absolute;
    top: -18%;
    width: 16vw;
    height: 130%;
    background: linear-gradient(180deg, color-mix(in srgb, var(--lagon) 26%, transparent), transparent 68%);
    transform: skewX(-14deg);
    will-change: transform, opacity;
  }
  .rays i:nth-child(1) { left: 6%; width: 10vw; opacity: 0.5; }
  .rays i:nth-child(2) { left: 30%; width: 18vw; opacity: 0.72; }
  .rays i:nth-child(3) { left: 58%; width: 9vw; opacity: 0.45; }
  .rays i:nth-child(4) { left: 76%; width: 14vw; opacity: 0.6; }

  /* ═══ CH.3 — LE RÉCIF ═══ */
  #recif {
    background: linear-gradient(180deg, var(--recif), var(--tempete));
    display: block;
  }
  .reef-glow {
    position: absolute;
    inset: auto 0 0;
    height: 46%;
    background: radial-gradient(80% 100% at 50% 100%, color-mix(in srgb, var(--cyan) 17%, transparent), transparent 72%);
    pointer-events: none;
  }
  .reef-track {
    display: flex;
    align-items: center;
    gap: clamp(40px, 6vw, 110px);
    width: max-content;
    height: 100vh;
    padding: 0 clamp(24px, 6vw, 90px);
    will-change: transform;
  }
  .reef-intro {
    width: min(620px, 82vw);
    flex-shrink: 0;
  }
  .reef-intro h2 {
    font-size: clamp(28px, 3.8vw, 46px);
    color: var(--blanc);
  }
  .reef-intro .beat-sub {
    margin-left: 0;
  }
  .reef-panel {
    position: relative;
    width: min(460px, 80vw);
    flex-shrink: 0;
    background: color-mix(in srgb, var(--marine) 55%, transparent);
    border: 1px solid color-mix(in srgb, var(--lagon) 22%, transparent);
    border-radius: 22px;
    padding: 34px 34px 30px 150px;
    min-height: 380px;
    -webkit-backdrop-filter: blur(6px);
    backdrop-filter: blur(6px);
  }
  .rack {
    position: absolute;
    left: 22px;
    bottom: 24px;
    width: 110px;
    height: 138px;
  }
  .coral {
    fill: color-mix(in srgb, var(--cyan) 55%, var(--bleu));
    opacity: 0.85;
  }
  .rack-body {
    fill: #0b2c44;
    stroke: color-mix(in srgb, var(--lagon) 45%, transparent);
    stroke-width: 1.4;
  }
  .rack-slot {
    fill: #0f3a58;
  }
  .led {
    fill: var(--lagon);
    animation: led-pulse 2.6s ease-in-out infinite;
  }
  @keyframes led-pulse {
    0%, 100% { opacity: 0.25; }
    50% { opacity: 1; }
  }
  .panel-depth {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.22em;
    color: var(--lagon);
    opacity: 0.8;
  }
  .reef-panel h3 {
    font-size: clamp(30px, 3vw, 40px);
    color: var(--blanc);
    margin-top: 6px;
  }
  .panel-tag {
    font-weight: 600;
    color: var(--lagon);
    margin-top: 6px;
  }
  .panel-desc {
    margin-top: 14px;
    font-size: 14.5px;
    line-height: 1.65;
    opacity: 0.8;
  }
  .panel-links {
    list-style: none;
    margin: 18px 0 0;
    padding: 0;
    display: grid;
    gap: 7px;
  }
  .panel-links a {
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
    color: var(--blanc);
    opacity: 0.85;
    transition: opacity 0.2s, color 0.2s;
  }
  .panel-links a:hover {
    opacity: 1;
    color: var(--lagon);
  }

  /* ═══ CH.4 — LA TEMPÊTE ═══ */
  #tempete {
    background: linear-gradient(180deg, var(--tempete) 0%, #030f1a 100%);
  }
  .storm-sky {
    position: absolute;
    inset: 0 0 auto;
    height: 42%;
    background:
      radial-gradient(70% 130% at 30% -30%, color-mix(in srgb, var(--orange) 14%, transparent), transparent 60%),
      linear-gradient(180deg, rgba(2, 8, 14, 0.92), transparent);
    will-change: opacity;
  }
  .flash {
    position: absolute;
    inset: 0;
    background: radial-gradient(60% 45% at 60% 0%, color-mix(in srgb, var(--orange) 55%, #fff), transparent 68%);
    opacity: 0;
    will-change: opacity;
    pointer-events: none;
  }
  .threats {
    position: absolute;
    top: 14%;
    left: 0;
    right: 0;
    overflow: hidden;
    -webkit-mask-image: linear-gradient(90deg, transparent, #000 12%, #000 88%, transparent);
    mask-image: linear-gradient(90deg, transparent, #000 12%, #000 88%, transparent);
  }
  .threat-row {
    display: flex;
    gap: 54px;
    width: max-content;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(34px, 5vw, 64px);
    letter-spacing: 0.04em;
    color: transparent;
    -webkit-text-stroke: 1.5px color-mix(in srgb, var(--orange) 65%, transparent);
    will-change: transform;
  }
  .beat-tempete h2 em {
    color: var(--orange);
  }
  .storm-tag {
    color: var(--orange);
  }
  .calm-card {
    margin: 36px auto 0;
    max-width: 520px;
    background: color-mix(in srgb, var(--marine) 66%, transparent);
    border: 1px solid color-mix(in srgb, var(--lagon) 30%, transparent);
    border-radius: 18px;
    padding: 26px 30px;
    box-shadow: 0 30px 80px rgba(0, 0, 0, 0.45);
    -webkit-backdrop-filter: blur(8px);
    backdrop-filter: blur(8px);
  }
  .calm-label {
    font-family: var(--font-mono);
    font-size: 11.5px;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--lagon);
  }
  .calm-line {
    margin-top: 10px;
    font-size: clamp(17px, 2vw, 21px);
  }
  .chrono {
    font-family: var(--font-display);
    font-size: 1.5em;
    color: var(--lagon);
  }

  /* ═══ CH.5 — LE RETOUR ═══ */
  #retour {
    background: linear-gradient(180deg, #030f1a 0%, var(--marine) 34%, var(--brand) 58%, #7a4a3a 82%, var(--dawn-orange) 100%);
  }
  .dawn {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }
  .sun {
    position: absolute;
    left: 50%;
    bottom: 6%;
    width: clamp(140px, 18vw, 260px);
    aspect-ratio: 1;
    transform: translateX(-50%);
